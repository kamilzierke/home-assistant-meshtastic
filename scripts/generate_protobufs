#!/usr/bin/env bash
#
# Regenerates custom_components/meshtastic/aiomeshtastic/protobuf/*_pb2.py(i)
# from the `protobufs` submodule. Requires `pip install -r requirements.protobuf.txt`
# (grpcio-tools provides the protoc compiler via `python -m grpc_tools.protoc`,
# mypy-protobuf provides the --mypy_out plugin).
#
# IMPORTANT: the generated *_pb2.py files embed a "gencode" protobuf version
# (fixed by whichever grpcio-tools release's bundled protoc binary you used -
# NOT controlled by the separately pip-installed `protobuf` package version)
# and refuse to import at runtime against an OLDER `protobuf` package - see
# https://protobuf.dev/support/cross-version-runtime-guarantee.
#
# Home Assistant core pins an EXACT `protobuf` version for the whole install in
# homeassistant/package_constraints.txt and rejects any custom integration
# requirement that doesn't satisfy it (RequirementsNotFound) - it will NOT
# resolve to something newer to satisfy us. So after running this script:
#   1. Check the "Protobuf Python Version: X.Y.Z" comment near the top of any
#      regenerated *_pb2.py file (the gencode version).
#   2. Check the exact `protobuf==A.B.C` pin in the target Home Assistant
#      version's homeassistant/package_constraints.txt.
#   3. Confirm A.B.C >= X.Y.Z. If not, you need an OLDER grpcio-tools release
#      (see requirements.protobuf.txt) whose bundled protoc produces an older
#      gencode - bumping our own `protobuf` requirement upward does NOT help,
#      since HA's own pin wins regardless of what we request.
#   4. Update custom_components/meshtastic/manifest.json's `protobuf>=X.Y.Z`
#      (matching the gencode floor from step 1) and requirements.txt's exact
#      pin (matching HA's A.B.C from step 2) accordingly.

set -e

cd "$(dirname "$0")/.."

BUILD_DIR="${PWD}/.build"

if [[ ! -d "${BUILD_DIR}" ]]; then
    mkdir -p "${BUILD_DIR}"
fi


# Put our temp files in the poetry build directory
TMPDIR="${BUILD_DIR}/protofixup"
echo "Fixing up protobuf paths in ${TMPDIR} temp directory"

# Ensure a clean build
[ -e "${TMPDIR}" ] && rm -r "${TMPDIR}"

INDIR="${TMPDIR}/in/meshtastic/aiomeshtastic/protobuf"
OUTDIR="${TMPDIR}/out"
PYIDIR="${TMPDIR}/out"
mkdir -p "${OUTDIR}" "${INDIR}" "${PYIDIR}"
cp "${PWD}/protobufs/meshtastic/"*.proto "${INDIR}"
cp "${PWD}/protobufs/nanopb.proto" "${INDIR}"

# OS-X sed is apparently a little different and expects an arg for -i
if [[ $OSTYPE == 'darwin'* ]]; then
  if which gsed >/dev/null; then
    SEDCMD="gsed -i -E"
  else
    SEDCMD="sed -i '' -E"
  fi
else
	SEDCMD="sed -i -E"
fi


# change the package names to meshtastic.aiomeshtastic.protobuf
$SEDCMD 's/^package meshtastic;/package meshtastic.aiomeshtastic.protobuf;/' "${INDIR}/"*.proto
# fix the imports to match
$SEDCMD 's/^import "meshtastic\//import "meshtastic\/aiomeshtastic\/protobuf\//' "${INDIR}/"*.proto
# adjust nanopb
$SEDCMD 's/^import "nanopb.proto";/import "meshtastic\/aiomeshtastic\/protobuf\/nanopb.proto";/' "${INDIR}/"*.proto

# Generate the python files
python3 -m grpc_tools.protoc -I="$TMPDIR/in" --python_out "${OUTDIR}" "--mypy_out=${PYIDIR}" "${INDIR}/"*.proto

# Change to relative imports
$SEDCMD 's/^from meshtastic.aiomeshtastic.protobuf import/from . import/' "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/"*pb2*.py
$SEDCMD 's/^import meshtastic.aiomeshtastic.protobuf.(.*)$/from . import \1/' "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/"*pb2*.pyi
$SEDCMD 's/\: meshtastic.aiomeshtastic.protobuf./: /' "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/"*pb2*.*
$SEDCMD 's/-> meshtastic.aiomeshtastic.protobuf./-> /' "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/"*pb2*.*
$SEDCMD 's/\[meshtastic.aiomeshtastic.protobuf./[/' "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/"*pb2*.*



PROTOBUF_VERSION=$(cd "${PWD}/protobufs" && git tag --points-at HEAD | sed 's/v\(.*\)/\1/')
# Create a __init__.py in the out directory with protobuf version
cat <<EOT > "${OUTDIR}/meshtastic/aiomeshtastic/protobuf/__init__.py"
__version__ = "$PROTOBUF_VERSION"
EOT

# Copy to the source controlled tree
mkdir -p custom_components/meshtastic/aiomeshtastic/protobuf
# Remove both generated .py and .pyi files first, so protos removed upstream
# don't leave orphaned stub files behind after regeneration.
rm -rf custom_components/meshtastic/aiomeshtastic/protobuf/*pb2*.py
rm -rf custom_components/meshtastic/aiomeshtastic/protobuf/*pb2*.pyi
cp "${OUTDIR}/meshtastic/aiomeshtastic/protobuf"/* custom_components/meshtastic/aiomeshtastic/protobuf

exit 0